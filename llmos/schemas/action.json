{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Action",
  "description": "Simplified action space for the agent. Tab/navigation management is done via click on UI buttons.",
  "type": "object",
  "required": ["action_type"],
  "properties": {
    "action_type": {
      "type": "string",
      "enum": [
        "click", "dblclick", "hover", "fill", "press", "focus", "clear", "select_option",
        "drag_and_drop", "scroll",
        "keyboard_press", "keyboard_type",
        "goto",
        "send_msg_to_user", "finish", "noop"
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "action_type": { "const": "click" } } },
      "then": {
        "required": ["bid"],
        "properties": {
          "bid": { "type": ["string", "integer"], "description": "Target element ID" },
          "button": { "type": "string", "enum": ["left", "right", "middle"], "default": "left" }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "dblclick" } } },
      "then": {
        "required": ["bid"],
        "properties": {
          "bid": { "type": ["string", "integer"], "description": "Target element ID" }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "hover" } } },
      "then": {
        "required": ["bid"],
        "properties": {
          "bid": { "type": ["string", "integer"], "description": "Target element ID to hover over" }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "fill" } } },
      "then": {
        "required": ["bid", "text"],
        "properties": {
          "bid": { "type": ["string", "integer"], "description": "Target element ID" },
          "text": { "type": "string", "description": "Text to fill" }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "press" } } },
      "then": {
        "required": ["bid", "key"],
        "properties": {
          "bid": { "type": ["string", "integer"], "description": "Target element ID" },
          "key": { "type": "string", "description": "Key combination (e.g., 'Enter', 'Ctrl+C')" }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "focus" } } },
      "then": {
        "required": ["bid"],
        "properties": {
          "bid": { "type": ["string", "integer"], "description": "Target element ID" }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "clear" } } },
      "then": {
        "required": ["bid"],
        "properties": {
          "bid": { "type": ["string", "integer"], "description": "Target element ID" }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "select_option" } } },
      "then": {
        "required": ["bid", "options"],
        "properties": {
          "bid": { "type": ["string", "integer"], "description": "Target element ID" },
          "options": { "type": "array", "items": { "type": "string" }, "description": "Options to select" }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "drag_and_drop" } } },
      "then": {
        "required": ["from_bid", "to_bid"],
        "properties": {
          "from_bid": { "type": ["string", "integer"], "description": "Source element ID to drag from" },
          "to_bid": { "type": ["string", "integer"], "description": "Target element ID to drop on" }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "scroll" } } },
      "then": {
        "required": ["bid", "direction"],
        "properties": {
          "bid": { "type": ["string", "integer"], "description": "Element to scroll (use 'root' for page)" },
          "direction": { "type": "string", "enum": ["up", "down", "left", "right"], "description": "Scroll direction" },
          "amount": { "type": "integer", "description": "Scroll amount in pixels (optional)", "default": 300 }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "keyboard_press" } } },
      "then": {
        "required": ["key"],
        "properties": { "key": { "type": "string", "description": "Key combination to press" } }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "keyboard_type" } } },
      "then": {
        "required": ["text"],
        "properties": { "text": { "type": "string", "description": "Text to type" } }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "goto" } } },
      "then": {
        "required": ["url"],
        "properties": { "url": { "type": "string", "description": "URL to navigate to" } }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "send_msg_to_user" } } },
      "then": {
        "required": ["text"],
        "properties": { "text": { "type": "string", "description": "Message to send" } }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "finish" } } },
      "then": {
        "required": ["success"],
        "properties": {
          "success": { "type": "boolean", "description": "Whether the agent believes the task is completed successfully" },
          "text": { "type": "string", "description": "Optional completion message" }
        }
      }
    }
  ]
}
