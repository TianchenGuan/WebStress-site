    "anchored_content": {
      "base_policy": {
        "standard_approval_limit": 90000,
        "pricing_change_notice_days": 30,
        "red_zone_vendor_limit": 90000
      },
      "amendments": [
        { "id": "A1", "title": "Enterprise Limit Adjustment", "date": "Jan 10, 2026", "status": "approved", "superseded": false, "change": "standard limit $90,000 -> $120,000" },
        { "id": "B2", "title": "Pricing Notice Alignment", "date": "Jan 18, 2026", "status": "approved", "superseded": false, "change": "enterprise pricing notice = 21 days" },
        { "id": "C3", "title": "Draft Risk Escalation", "date": "Jan 22, 2026", "status": "superseded", "superseded": true, "change": "proposed standard limit $140,000 (superseded by D4-ERRATA)" },
        { "id": "D4-ERRATA", "title": "Errata and Correction", "date": "Jan 24, 2026", "status": "approved", "superseded": false, "change": "final standard limit = $125,000, red-zone remains $90,000" },
        { "id": "E5", "title": "Travel Expense Clarification", "date": "Jan 27, 2026", "status": "approved", "superseded": false, "change": "travel reimbursement cap $4,000/quarter" },
        { "id": "F6", "title": "Small Vendor Fast Lane", "date": "Jan 30, 2026", "status": "approved", "superseded": false, "change": "non-enterprise vendors <= $25,000 use one-click approval" },
        { "id": "G7", "title": "Sandbox Pricing Pilot", "date": "Feb 2, 2026", "status": "approved", "superseded": false, "change": "pilot sandbox 14-day pricing notice (does NOT replace enterprise policy)" },
        { "id": "H8", "title": "Administrative Clean-up", "date": "Feb 6, 2026", "status": "approved", "superseded": false, "change": "metadata updates only, no numerical changes" },
        { "id": "I9", "title": "Red-Zone Escalation Notice", "date": "Feb 8, 2026", "status": "approved", "superseded": false, "change": "red-zone vendors require 28-day pricing notice (does NOT apply to standard)" },
        { "id": "J10", "title": "Supersession Mapping Note", "date": "Feb 10, 2026", "status": "approved", "superseded": false, "change": "D4-ERRATA supersedes A1 and C3 for standard enterprise limit" }
      ],
      "final_standard_values": {
        "approval_limit": 125000,
        "pricing_notice_days": 21,
        "controlling_memo_for_limit": "D4-ERRATA",
        "controlling_memo_for_notice": "B2"
      },
      "evidence_key": "D4-B2-21",
      "evidence_key_rule": "controlling-memo-for-limit + controlling-memo-for-notice + notice-days"
    },
    "task_completion_criteria": {
      "js_eval": [
        "data.report_submitted === true",
        "data.compare_mode_used === true",
        "data.final_limit === 125000",
        "data.notice_days === 21",
        "String(data.source_memo_id || '').indexOf('D4') !== -1",
