          {
            "bid": "paragraph_you_agree_not_to_disclose_your_password_10",
            "tag": "p",
            "role": "paragraph",
            "text": "You agree not to disclose your password to any third party. You must notify us immediately upon becoming aware of any breach of security or unauthorized use of your account. We reserve the right to suspend or terminate accounts that violate these Terms or engage in fraudulent activity.",
