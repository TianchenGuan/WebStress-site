      "required_config": {
        "mapping_profile": "stable-v3",
        "include_archived": false,
        "normalization_mode": "strict-canonical"
      },
      "dry_run_stages": 2,
      "token_value": "MG-7712",
      "validation_stamp": "STAMP-44",
      "workflow": [
        "Configure mapping (stable-v3, exclude archived, strict-canonical normalization)",
        "Pass dry-run stage 1 of 2",
        "Pass dry-run stage 2 of 2 (mints token MG-7712)",
        "Perform real commit",
        "Validate token (enter MG-7712)",
        "Submit audit token and validation stamp (STAMP-44)"
      ]
    },
    "task_completion_criteria": {
      "js_eval": [
        "data.final_submitted === true",
        "data.submission_successful === true",
        "data.mapping_profile === 'stable-v3'",
        "data.include_archived === false",
        "data.normalization_mode === 'strict-canonical'",
        "data.dry_run_pass_count >= 2",
        "data.dry_run_passed === true",
        "data.real_commit_done === true",
        "data.token_validated === true",
        "data.quick_commit_clicked === false",
        "data.token_entered === data.token_generated",
        "data.validation_stamp_entered === data.validation_stamp_generated"
      ],
      "dom_check": [
        {
          "selector": "#final-result",
          "condition": "contains",
          "value": "accepted"
        }
      ]
    }
  },
