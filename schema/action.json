{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "action.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "click",
        "double_click",
        "right_click",
        "drag",
        "scroll",
        "keypress",
        "input_text",
        "hotkey",
        "noop",
        "finish"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "element_id": {"type": "string"},
        "x": {"type": "number"},
        "y": {"type": "number"}
      }
    },
    "text": {"type": "string"},
    "keys": {
      "type": "array",
      "items": {"type": "string"}
    },
    "delta_y": {"type": "number"},
    "delta_x": {"type": "number"}
  }
}
