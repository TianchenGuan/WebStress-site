{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "instruction.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "description", "template", "success_criteria", "difficulty", "time_limit"],
  "properties": {
    "id": {"type": "string"},
    "description": {"type": "string"},
    "template": {"type": "string"},
    "difficulty": {"type": "string"},
    "time_limit": {"type": "integer"},
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["predicate"],
        "properties": {
          "predicate": {"type": "string"},
          "weight": {"type": "number"},
          "notes": {"type": "string"}
        }
      }
    },
    "config": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {"type": "string"},
          "parameters": {"type": "object"}
        },
        "additionalProperties": true
      }
    }
  }
}
