{
  "actions": [
    {
      "type": "double_click",
      "description": "Launch desktop icons or list items that open applications.",
      "required_fields": [
        "target.element_id"
      ],
      "example": {
        "type": "double_click",
        "target": {
          "element_id": "icon_browser"
        }
      }
    },
    {
      "type": "click",
      "description": "Press buttons, menu items, tabs, links, toggles, or focus inputs.",
      "required_fields": [
        "target.element_id"
      ],
      "example": {
        "type": "click",
        "target": {
          "element_id": "menu_item_settings"
        }
      }
    },
    {
      "type": "input_text",
      "description": "Type text into the currently focused input field.",
      "required_fields": [
        "text"
      ],
      "example": {
        "type": "input_text",
        "target": {
          "element_id": "address_bar"
        },
        "text": "make bing default"
      }
    },
    {
      "type": "scroll",
      "description": "Scroll vertically through content.",
      "required_fields": [
        "delta_y"
      ],
      "example": {
        "type": "scroll",
        "delta_y": 240
      }
    },
    {
      "type": "hotkey",
      "description": "Send key combinations.",
      "required_fields": [
        "keys"
      ],
      "example": {
        "type": "hotkey",
        "keys": [
          "CTRL",
          "L"
        ]
      }
    },
    {
      "type": "noop",
      "description": "Wait when no safe or useful action exists.",
      "required_fields": [],
      "example": {
        "type": "noop"
      }
    }
  ]
}