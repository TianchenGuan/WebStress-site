# Copy this file to webagentbench/.env and fill in the keys you need.
# The file is loaded by webagentbench/stock_browseruse_eval.py at import time.
# `webagentbench/.env` is in .gitignore — never commit real keys.

# --- AWS Bedrock (provider=bedrock / anthropic_bedrock) --------------------
# One-time bearer token issued in the Bedrock console under
#   "API keys" → "Create long-term API key".
AWS_BEDROCK_API_KEY=
AWS_BEDROCK_REGION=us-east-1

# --- Google Gemini (provider=gemini) ---------------------------------------
GEMINI_API_KEY=

# --- OpenAI (provider=openai) ----------------------------------------------
OPENAI_API_KEY=
# Optional: route to Azure / vLLM / LiteLLM with an OpenAI-compatible base URL.
# OPENAI_API_BASE_URL=

# --- Anthropic direct (provider=anthropic) ---------------------------------
ANTHROPIC_API_KEY=

# --- OpenRouter (provider=openrouter) --------------------------------------
OPENROUTER_API_KEY=

# --- Local vLLM (provider=vllm) --------------------------------------------
# WEBAGENTBENCH_API_BASE_URL=http://localhost:8000/v1
# WEBAGENTBENCH_API_KEY=dummy
