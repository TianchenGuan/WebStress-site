# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Virtual environments
.venv/
.uv/

# Git worktrees
.worktrees/

# Environment and local config
.env
.env.*
config.json

# Editor state
.vscode/
.idea/
.DS_Store

# Node
node_modules/
.tools/

# Test and lint caches
.pytest_cache/
.ruff_cache/

# NFS silly-rename lock files (auto-created when a held file is deleted over NFS).
# These must never be git-added — happened once and broke a rebase.
**/.nfs*

# Benchmark outputs
runs/
runs*
results/
results_*
trajectory/
history/
raw_instructions/
# NOTE: webagentbench/human/traces/ is explicitly tracked (annotator recordings).
# Agent trajectories (webagentbench/trajectories/, gold_trajectories/) remain ignored below.

# Local planning scratch files
task_plan.md
findings.md
progress.md

# Slurm job artifacts (outputs + sbatch scripts are per-run, not checked in)
logs/
scripts/slurm/
audits/

# Debug artifacts
tmp.py
tmp.json
tmp.html
scripts/*.txt
scripts/*.pkl
scripts/_*/
scripts/.debug_*.json
scripts/.gmail_session*.json
scripts/.rh_session*.json
scripts/.lms_session*.json
scripts/.pp_session*.json
scripts/debug_screenshots/
*.pdf
*.log

# Frontend and generated benchmark assets
*.tsbuildinfo
webagentbench/static/*.html
!webagentbench/static/docs.html
!webagentbench/static/control.html
!webagentbench/static/human.html
!webagentbench/static/human_control.html
webagentbench/static/envs/
webagentbench/static/.frontend-build.lock
webagentbench/trajectories/*
webagentbench/.codex
webagentbench/.playwright-mcp/*
.vercel
.claude/
